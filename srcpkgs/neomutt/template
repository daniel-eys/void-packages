# Template file for 'neomutt'
pkgname=neomutt
version=20200821
revision=1
_testfilescommit=8629adab700a75c54e8e28bf05ad092503a98f75
wrksrc="neomutt-${version}"
create_wrksrc=true
build_wrksrc="$wrksrc"
build_style=configure
configure_args="--disable-idn --gpgme --idn2 --lmdb --lua --notmuch --sasl --ssl
 --testing --zlib --zstd"
make_check_target=test
conf_files="/etc/neomuttrc"
# neomutt needs either w3m/lynx/elinks to build manual.html
hostmakedepends="docbook-xsl gettext libxslt perl tcl w3m"
makedepends="aspell-devel gettext-devel gpgme-devel libidn2-devel libnotmuch-devel
 libressl-devel libsasl-devel lmdb-devel lua54-devel zlib-devel libzstd-devel"
depends="mime-types"
short_desc="Mutt with misc fixes and feature patches"
maintainer="Daniel Eyßer <daniel.eysser@gmail.com>"
license="GPL-2.0-or-later"
homepage="https://neomutt.org/"
distfiles="https://github.com/neomutt/neomutt/archive/${version}.tar.gz
 https://github.com/neomutt/neomutt-test-files/archive/${_testfilescommit}.tar.gz"
checksum="4233d03e03220a2ba8096ab28061e12ef538259fd7d32ad441aad5207b17b390
 a53d6447cf4e8f60bd9a3caf68a1cfe1bfda878b5bcb8c60b965b5214de73ff9"
python_version=3

if [ "${XBPS_CROSS_BASE}" ]; then
	configure_args="${configure_args} --host=$XBPS_CROSS_TRIPLET"
	configure_args="${configure_args} --build=$XBPS_TRIPLET"
	configure_args="${configure_args} --with-sysroot=$XBPS_CROSS_BASE"
fi

case "${XBPS_TARGET_MACHINE}" in
	x86_64-musl) CFLAGS="-D_FILE_OFFSET_BITS=64 -DLARGEFILE_SOURCE=1";;
esac

pre_check() {
	(
	 cd ${wrksrc}/neomutt-test-files-${_testfilescommit}/
	 ./setup.sh
	)
	export NEOMUTT_TEST_DIR=${wrksrc}/neomutt-test-files-${_testfilescommit}
}

post_check() {
	# This is a file chmodded to 311 and can't be removed normally
	chmod 777 ${wrksrc}/neomutt-test-files-${_testfilescommit}/maildir/damson
}

post_install() {
	vsconf contrib/gpg.rc Muttrc.gpg.dist
}
