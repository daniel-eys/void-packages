 	marks           map[string]string
 	renameCache     []string
 	selections      map[string]int
@@ -351,6 +352,7 @@ func newNav(height int) *nav {
 		dirCache:        make(map[string]*dir),
 		regCache:        make(map[string]*reg),
 		saves:           make(map[string]bool),
+		tags:            make(map[string]bool),
 		marks:           make(map[string]string),
 		renameCache:     make([]string, 2),
 		selections:      make(map[string]int),
@@ -608,6 +610,21 @@ func (nav *nav) toggleSelection(path string) {
 	}
 }
 
+func (nav *nav) toggleTag() {
+	curr, err := nav.currFile()
+	if err != nil {
+		return
+	}
+
+	if nav.tags[curr.path] {
+		delete(nav.tags, curr.path)
+	} else {
+		nav.tags[curr.path] = true
+	}
+
+	nav.down(1)
+}
+
 func (nav *nav) toggle() {
 	curr, err := nav.currFile()
 	if err != nil {
@@ -851,7 +868,15 @@ func (nav *nav) sync() error {
 		nav.saves[f] = cp
 	}
 
-	return nav.readMarks()
+	if err := nav.readMarks(); err != nil {
+		return err
+	}
+
+	if err := nav.readTags(); err != nil {
+		return err
+	}
+
+	return nil
 }
 
 func (nav *nav) cd(wd string) error {
@@ -1112,6 +1137,29 @@ func (nav *nav) readMarks() error {
 	return nil
 }
 
+func (nav *nav) readTags() error {
+	nav.tags = make(map[string]bool)
+	f, err := os.Open(gTagsPath)
+	if os.IsNotExist(err) {
+		return nil
+	}
+	if err != nil {
+		return fmt.Errorf("opening tags file: %s", err)
+	}
+	defer f.Close()
+
+	scanner := bufio.NewScanner(f)
+	for scanner.Scan() {
+		nav.tags[scanner.Text()] = true
+	}
+
+	if err := scanner.Err(); err != nil {
+		return fmt.Errorf("reading tags file: %s", err)
+	}
+
+	return nil
+}
+
 func (nav *nav) writeMarks() error {
 	if err := os.MkdirAll(filepath.Dir(gMarksPath), os.ModePerm); err != nil {
 		return fmt.Errorf("creating data directory: %s", err)
@@ -1139,6 +1187,27 @@ func (nav *nav) writeMarks() error {
 	return nil
 }
 
+func (nav *nav) writeTags() error {
+	if err := os.MkdirAll(filepath.Dir(gTagsPath), os.ModePerm); err != nil {
+		return fmt.Errorf("creating data directory: %s", err)
+	}
+
+	f, err := os.Create(gTagsPath)
+	if err != nil {
+		return fmt.Errorf("creating tags file: %s", err)
+	}
+	defer f.Close()
+
+	for k := range nav.tags {
+		_, err = f.WriteString(fmt.Sprintf("%s\n", k))
+		if err != nil {
+			return fmt.Errorf("writing tags file: %s", err)
+		}
+	}
+
+	return nil
+}
+
 func (nav *nav) currDir() *dir {
 	return nav.dirs[len(nav.dirs)-1]
 }
